{
	"compilerOptions": {
		"target": "ES2020",
		"module": "Node16",
		"moduleResolution": "node16",
		"esModuleInterop": true,
		"strict": true,
		"outDir": "dist",
		"rootDir": ".",
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"types": ["node"]
	},
	"include": ["agent/**/*", "src/**/*"],
	"exclude": ["node_modules", "ui", "dist"]
}
