{
	"compilerOptions": {
		"target": "ES2020",
		"module": "node16",
		"moduleResolution": "node16",
		"esModuleInterop": true,
		"strict": true,
		"outDir": "dist",
		"rootDir": ".",
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"types": ["node"]
	},
	"include": ["agent/**/*"],
	"exclude": ["node_modules", "ui"]
}
