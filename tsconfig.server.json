{
	"compilerOptions": {
		"target": "ES2020",
		"module": "Node16",
		"moduleResolution": "node16",
		"esModuleInterop": true,
		"strict": true,
		"outDir": "dist-server",
		"rootDir": ".",
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"types": ["node"]
	},
	"include": ["server/**/*", "src/**/*", "agent/lib/**/*"],
	"exclude": ["node_modules", "ui"]
}
