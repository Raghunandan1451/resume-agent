{
	"compilerOptions": {
		"target": "ES2020",
		"module": "CommonJS",
		"moduleResolution": "node16",
		"esModuleInterop": true,
		"strict": true,
		"outDir": "dist-server",
		"rootDir": ".",
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"types": ["node"]
	},
	"include": ["server/**/*"],
	"exclude": ["node_modules", "ui"]
}
