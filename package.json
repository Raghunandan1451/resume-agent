{
	"name": "resume-agent",
	"version": "1.0.0",
	"description": "Local AI resume tailor + diff viewer",
	"scripts": {
		"apply": "ts-node agent/apply.ts",
		"tailor": "ts-node agent/tailor.ts",
		"compile": "ts-node agent/compile.ts",
		"compile:base": "ts-node agent/compile.ts --base",
		"cover-letter": "ts-node agent/cover-letter.ts",
		"email": "ts-node agent/email.ts",
		"server": "ts-node --project tsconfig.server.json server/index.ts",
		"ui": "cd ui && npm run dev",
		"dev": "concurrently \"npm run server\" \"npm run ui\"",
		"setup": "npm install && cd ui && npm install"
	},
	"devDependencies": {
		"typescript": "^5.4.0",
		"ts-node": "^10.9.2",
		"@types/node": "^20.0.0",
		"@types/express": "^4.17.21",
		"@types/cors": "^2.8.17",
		"concurrently": "^8.2.0"
	},
	"dependencies": {
		"express": "^4.18.2",
		"cors": "^2.8.5"
	}
}
